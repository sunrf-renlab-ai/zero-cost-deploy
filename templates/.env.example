# Copy to .env.local for local dev. NEVER commit a filled-in version.
#
# After filling in values for production, paste the whole block (one line per
# KEY=VALUE) into Vercel's env form using the ClipboardEvent paste trick.
# See SKILL.md "④ Vercel" for the exact flow.

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_replace_me
SUPABASE_SERVICE_ROLE_KEY=sb_secret_replace_me_SERVER_ONLY

# === Upstash Redis ===
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace_me

# === Render service (long-running endpoints) ===
NEXT_PUBLIC_ORCHESTRATOR_URL=https://your-service.onrender.com

# === Inter-service auth (Vercel ↔ Render) ===
# Same value MUST be set in both Vercel and Render env.
INTERNAL_RPC_TOKEN=generate-via-gen-secrets.sh

# === Cron route authorization ===
CRON_SECRET=generate-via-gen-secrets.sh

# === App-level encryption (AES-GCM) for at-rest user secrets ===
APP_ENCRYPTION_KEY=generate-via-gen-secrets.sh

# === Optional: Sentry ===
# SENTRY_DSN=https://...
# NEXT_PUBLIC_SENTRY_DSN=https://...

# === Optional: site URL for OG metadata / absolute links ===
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# === Generated by gen-secrets.sh (uncomment if your app uses them) ===
# WEBHOOK_HMAC_SECRET=
# SESSION_SECRET=

# === Stripe (payments) ===
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# === Resend (email) ===
# RESEND_API_KEY=

# === Clerk (auth — alternative to Supabase Auth) ===
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
# CLERK_SECRET_KEY=sk_...

# === PostHog (analytics) ===
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# === Pinecone (vectors — alternative to Supabase pgvector) ===
# PINECONE_API_KEY=
